// ScreenTest.vm
// Draws a 16-pixel horizontal line at the top-left of the screen.

function Main.main 0
    // 1. Push the base address of the Screen (16384)
    push constant 16384
    
    // 2. Map this to the 'pointer' segment 
    // This sets THAT to point to the screen memory
    pop pointer 1
    
    // 3. Create a "pattern" of pixels (1111111111111111)
    // In 2's complement, -1 is 16 bits of 1s
    push constant 1
    neg
    
    // 4. Write the pattern to the first 'word' of the screen
    // This targets THAT 0 (which is now RAM[16384])
    pop that 0

    // 5. Infinite loop to keep the screen visible
label END
    goto END